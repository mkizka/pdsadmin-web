{
  "name": "pdsadmin-web",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "run-s -sl setup-dev-env reset-dev-env && run-p -srl run-dev-env dev:vite",
    "dev:vite": "wait-on http://localhost:2583 && vite --host",
    "e2e": "playwright test",
    "format": "eslint . --fix && prettier . --write",
    "lint": "eslint . && prettier . --check",
    "prepare": "husky",
    "preview": "pnpm reset-dev-env && run-p -srl run-dev-env preview:vite",
    "preview:vite": "wait-on http://localhost:2583 && sleep 5 && vite preview",
    "reset-dev-env": "./scripts/reset-dev-env.sh",
    "run-dev-env": "./scripts/run-dev-env.sh",
    "setup-dev-env": "./scripts/setup-dev-env.sh",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@atcute/client": "4.2.1",
    "@conform-to/react": "1.19.0",
    "@conform-to/zod": "1.19.0",
    "@tailwindcss/vite": "4.2.2",
    "clsx": "2.1.1",
    "i18next": "25.10.10",
    "i18next-browser-languagedetector": "8.2.1",
    "jotai": "2.19.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "16.6.6",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@atcute/atproto": "3.1.11",
    "@egoist/tailwindcss-icons": "1.9.2",
    "@iconify-json/lucide": "1.2.104",
    "@iconify-json/simple-icons": "1.2.80",
    "@mkizka/eslint-config": "7.2.0",
    "@playwright/test": "1.59.1",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.0",
    "daisyui": "5.5.19",
    "eslint": "9.39.4",
    "eslint-plugin-react-refresh": "0.5.2",
    "giget": "2.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-pkg": "0.22.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "wait-on": "9.0.5"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": "eslint --fix",
    "*": "prettier --ignore-unknown --write"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg",
      "prettier-plugin-tailwindcss"
    ]
  }
}
