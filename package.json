{
  "name": "pdsadmin-web",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "run-s -sl setup-dev-env reset-dev-env && run-p -srl run-dev-env dev:vite",
    "dev:vite": "wait-on http://localhost:2583 && vite --host",
    "e2e": "playwright test",
    "format": "eslint . --fix && prettier . --write",
    "lint": "eslint . && prettier . --check",
    "prepare": "husky",
    "preview": "pnpm reset-dev-env && run-p -srl run-dev-env preview:vite",
    "preview:vite": "wait-on http://localhost:2583 && sleep 30 && vite preview",
    "reset-dev-env": "./scripts/reset-dev-env.sh",
    "run-dev-env": "./scripts/run-dev-env.sh",
    "setup-dev-env": "./scripts/setup-dev-env.sh",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@atcute/client": "5.0.0",
    "@conform-to/react": "1.19.4",
    "@conform-to/zod": "1.19.4",
    "@tailwindcss/vite": "4.3.0",
    "clsx": "2.1.1",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "jotai": "2.20.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@atcute/atproto": "4.0.2",
    "@egoist/tailwindcss-icons": "1.9.2",
    "@iconify-json/lucide": "1.2.111",
    "@iconify-json/simple-icons": "1.2.86",
    "@mkizka/eslint-config": "10.0.0",
    "@playwright/test": "1.60.0",
    "@types/node": "24.13.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "daisyui": "5.5.23",
    "eslint": "10.4.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "giget": "3.2.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.4",
    "prettier-plugin-pkg": "0.22.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "wait-on": "9.0.10"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": "eslint --fix",
    "*": "prettier --ignore-unknown --write"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg",
      "prettier-plugin-tailwindcss"
    ]
  }
}
